# ==================== 自定义规则 ====================
# 1. 禁止提交 Word / PPT 文件
*.ppt
*.pptx
*.doc
*.docx

# 2. 强制允许 BAT 文件（必须上传 GitHub）
!*.bat


# ==================== 通用忽略规则 ====================
# 系统文件
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# 编辑器/IDE
.idea/
.vscode/
*.swp
*.swo
*~
*.bak

# 依赖与构建
node_modules/
vendor/
dist/
build/
out/

# 日志
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 环境配置
.env
.env.local

# 临时文件
*.tmp
*.temp