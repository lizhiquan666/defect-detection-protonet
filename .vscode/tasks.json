{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "CMake: build debug (Ninja)",
            "type": "process",
            "command": "cmake",
            "args": [
                "--build",
                "${workspaceFolder}/build",
                "--config",
                "Debug",
                "-j"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": ["$msCompile"],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "panel": "new",
                "echo": true,
                "reveal": "always"
            }
        }
    ]
}